:root {
    --neon-red: #ff003c;
    --neon-blue: #00f3ff;
    --dark-bg: #050505;
    --card-bg: #0c0c0e;
    --font-futuristic: 'Orbitron', sans-serif;
    --font-clean: 'Rajdhani', sans-serif;
}

body {
    background-color: var(--dark-bg);
    color: white;
    font-family: var(--font-clean);
    margin: 0;
    overflow-x: hidden;
}

.scanline {
    width: 100%; height: 100px;
    background: linear-gradient(0deg, rgba(0,0,0,0) 0%, rgba(255,255,255,0.05) 50%, rgba(0,0,0,0) 100%);
    opacity: 0.1; position: fixed; bottom: 100%; left: 0;
    z-index: 100; pointer-events: none;
    animation: scanline 8s linear infinite;
}
@keyframes scanline { 0% { bottom: 100%; } 100% { bottom: -100%; } }

header {
    height: 60vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: radial-gradient(circle at center, #1a0000 0%, #000 80%);
    border-bottom: 2px solid var(--neon-red);
    text-align: center;
}

nav {
    position: absolute; top: 0; width: 100%;
    display: flex; justify-content: space-around;
    padding: 30px 0;
}

.logo { font-family: var(--font-futuristic); font-size: 2rem; }
.logo span { color: var(--neon-red); text-shadow: 0 0 10px var(--neon-red); }

.status-box { color: var(--neon-blue); border: 1px solid var(--neon-blue); padding: 5px 15px; font-size: 0.8rem; }

.hero h1 { font-family: var(--font-futuristic); font-size: 3rem; margin: 0; }
.hero h1 span { color: var(--neon-red); }

.author-tag { margin-top: 20px; border-left: 4px solid var(--neon-red); padding-left: 15px; font-weight: bold; }

.about { padding: 60px 20px; text-align: center; background: #080808; }
.about-text { font-size: 1.2rem; color: #aaa; max-width: 800px; margin: 0 auto; line-height: 1.6; }

.container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
.section-title { font-family: var(--font-futuristic); color: var(--neon-red); text-align: center; margin: 40px 0; }

.grid-catalog { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }

.neon-card { background: var(--card-bg); border: 1px solid #222; border-radius: 10px; overflow: hidden; transition: 0.4s; }
.neon-card:hover { border-color: var(--neon-red); transform: translateY(-10px); }

.img-container { height: 220px; }
.img-container img { width: 100%; height: 100%; object-fit: cover; }

.card-content { padding: 25px; text-align: left; }
.var-badge { margin-top: 15px; font-family: monospace; color: var(--neon-red); background: rgba(255,0,0,0.1); padding: 8px; border-radius: 5px; display: block; }
.type { color: var(--neon-blue); }

.data-center { padding: 60px 0; }
.glass-table-container { background: rgba(255,255,255,0.02); border: 1px solid #222; border-radius: 10px; overflow: hidden; }
table { width: 100%; border-collapse: collapse; }
th, td { padding: 15px; border-bottom: 1px solid #111; text-align: left; }
th { background: var(--neon-red); color: white; font-family: var(--font-futuristic); }

footer { text-align: center; padding: 40px; border-top: 1px solid #222; color: #444; font-size: 0.8rem; }
